{
  "id": null,
  "uid": "signalman-red",
  "title": "Signalman — Booking Saga RED Metrics",
  "description": "Rate, Errors, and Duration across every saga step. Use the Tempo datasource to jump from a metric to the trace that explains it.",
  "tags": ["signalman", "red", "saga"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "uid": "prometheus", "type": "prometheus" },
        "query": "label_values(signalman_operation_duration_count, service_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (rps)",
      "description": "Operations per second by service and operation. Rate = saga throughput.",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name, operation) (rate(signalman_operation_duration_count{service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}} / {{operation}}",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate (rps)",
      "description": "Errors per second by service and operation. Spike here = dig into Tempo.",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name, operation) (rate(signalman_operation_errors_total{service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}} / {{operation}}",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P99 Latency (ms)",
      "description": "99th-percentile operation latency. SLO breach here → check Tempo for the slow booking.",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, service_name, operation) (rate(signalman_operation_duration_bucket{service_name=~\"$service\"}[5m]))) * 1000",
          "legendFormat": "p99 {{service_name}} / {{operation}}",
          "instant": false
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le, service_name, operation) (rate(signalman_operation_duration_bucket{service_name=~\"$service\"}[5m]))) * 1000",
          "legendFormat": "p50 {{service_name}} / {{operation}}",
          "instant": false,
          "hide": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error Ratio (%)",
      "description": "Error percentage per service. Useful for SLO burn-rate alerting.",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (service_name) (rate(signalman_operation_errors_total{service_name=~\"$service\"}[5m])) / sum by (service_name) (rate(signalman_operation_duration_count{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Requests (last 15m)",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(signalman_operation_duration_count{service_name=~\"$service\"}[15m]))",
          "legendFormat": "",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Errors (last 15m)",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(signalman_operation_errors_total{service_name=~\"$service\"}[15m]))",
          "legendFormat": "",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "P99 Latency — gateway (ms)",
      "description": "P99 latency for the POST /bookings route — the end-to-end saga duration.",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(signalman_operation_duration_bucket{service_name=\"gateway\"}[5m]))) * 1000",
          "legendFormat": "",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Supplier P99 Latency (ms)",
      "description": "P99 latency of the supplier leg — the deliberately slow external boundary.",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(signalman_operation_duration_bucket{service_name=\"supplier\"}[5m]))) * 1000",
          "legendFormat": "",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Operation Summary",
      "description": "Current rate, error rate, and P99 latency per service + operation.",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "refId": "rate",
          "expr": "sum by (service_name, operation) (rate(signalman_operation_duration_count{service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}} / {{operation}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "errors",
          "expr": "sum by (service_name, operation) (rate(signalman_operation_errors_total{service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}} / {{operation}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (le, service_name, operation) (rate(signalman_operation_duration_bucket{service_name=~\"$service\"}[5m]))) * 1000",
          "legendFormat": "{{service_name}} / {{operation}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "service_name": "Service",
              "operation": "Operation",
              "Value #rate": "Rate (rps)",
              "Value #errors": "Error Rate (rps)",
              "Value #p99": "P99 (ms)"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "stack": true
            },
            "indexByName": {
              "Service": 0,
              "Operation": 1,
              "Rate (rps)": 2,
              "Error Rate (rps)": 3,
              "P99 (ms)": 4
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rate (rps)" },
            "properties": [{ "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 3 }]
          },
          {
            "matcher": { "id": "byName", "options": "Error Rate (rps)" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "decimals", "value": 3 },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "custom.displayMode", "value": "color-text" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 0.001 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99 (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 0 },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "custom.displayMode", "value": "color-text" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 200 },
                    { "color": "red", "value": 1000 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Service", "desc": false }],
        "footer": { "show": false }
      }
    }
  ]
}

{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "services/gateway/src",
  "monorepo": true,
  "root": "services/gateway",
  "compilerOptions": {
    "webpack": false,
    "deleteOutDir": true,
    "tsConfigPath": "services/gateway/tsconfig.app.json"
  },
  "projects": {
    "gateway": {
      "type": "application",
      "root": "services/gateway",
      "entryFile": "main",
      "sourceRoot": "services/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "services/gateway/tsconfig.app.json"
      }
    },
    "coordinator": {
      "type": "application",
      "root": "services/coordinator",
      "entryFile": "main",
      "sourceRoot": "services/coordinator/src",
      "compilerOptions": {
        "tsConfigPath": "services/coordinator/tsconfig.app.json",
        "assets": [{ "include": "proto/**/*.proto", "outDir": "dist/services/coordinator" }]
      }
    },
    "inventory": {
      "type": "application",
      "root": "services/inventory",
      "entryFile": "main",
      "sourceRoot": "services/inventory/src",
      "compilerOptions": {
        "tsConfigPath": "services/inventory/tsconfig.app.json",
        "assets": [{ "include": "proto/**/*.proto", "outDir": "dist/services/inventory" }]
      }
    },
    "payments": {
      "type": "application",
      "root": "services/payments",
      "entryFile": "main",
      "sourceRoot": "services/payments/src",
      "compilerOptions": {
        "tsConfigPath": "services/payments/tsconfig.app.json",
        "assets": [{ "include": "proto/**/*.proto", "outDir": "dist/services/payments" }]
      }
    },
    "supplier": {
      "type": "application",
      "root": "services/supplier",
      "entryFile": "main",
      "sourceRoot": "services/supplier/src",
      "compilerOptions": {
        "tsConfigPath": "services/supplier/tsconfig.app.json",
        "assets": [{ "include": "proto/**/*.proto", "outDir": "dist/services/supplier" }]
      }
    },
    "ledger": {
      "type": "application",
      "root": "services/ledger",
      "entryFile": "main",
      "sourceRoot": "services/ledger/src",
      "compilerOptions": {
        "tsConfigPath": "services/ledger/tsconfig.app.json",
        "assets": [{ "include": "proto/**/*.proto", "outDir": "dist/services/ledger" }]
      }
    },
    "otel": {
      "type": "library",
      "root": "libs/otel",
      "entryFile": "index",
      "sourceRoot": "libs/otel/src",
      "compilerOptions": {
        "tsConfigPath": "libs/otel/tsconfig.lib.json"
      }
    },
    "propagation": {
      "type": "library",
      "root": "libs/propagation",
      "entryFile": "index",
      "sourceRoot": "libs/propagation/src",
      "compilerOptions": {
        "tsConfigPath": "libs/propagation/tsconfig.lib.json"
      }
    },
    "logging": {
      "type": "library",
      "root": "libs/logging",
      "entryFile": "index",
      "sourceRoot": "libs/logging/src",
      "compilerOptions": {
        "tsConfigPath": "libs/logging/tsconfig.lib.json"
      }
    },
    "interceptor": {
      "type": "library",
      "root": "libs/interceptor",
      "entryFile": "index",
      "sourceRoot": "libs/interceptor/src",
      "compilerOptions": {
        "tsConfigPath": "libs/interceptor/tsconfig.lib.json"
      }
    },
    "outbox": {
      "type": "library",
      "root": "libs/outbox",
      "entryFile": "index",
      "sourceRoot": "libs/outbox/src",
      "compilerOptions": {
        "tsConfigPath": "libs/outbox/tsconfig.lib.json"
      }
    },
    "inbox": {
      "type": "library",
      "root": "libs/inbox",
      "entryFile": "index",
      "sourceRoot": "libs/inbox/src",
      "compilerOptions": {
        "tsConfigPath": "libs/inbox/tsconfig.lib.json"
      }
    }
  }
}
